APP_NAME=AutoWala
APP_ENV=testing
APP_KEY=base64:QktT6PcmrYrFZhGQGgHNuMh7y5bkjWCkbMPZD9WTHKA=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_LEVEL=debug

# Test Database (CI/CD uses PostgreSQL service container)
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=autowala_test
DB_USERNAME=postgres
DB_PASSWORD=postgres

# Redis for Testing
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

CACHE_DRIVER=array
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=array
SESSION_LIFETIME=120

# JWT Configuration
JWT_SECRET=base64:TestJWTSecretKeyForTesting1234567890abcdef
JWT_TTL=60
JWT_REFRESH_TTL=20160
JWT_ALGO=HS256

# Firebase Configuration (Test values)
FIREBASE_PROJECT_ID=autowala-test
FIREBASE_DATABASE_URL=https://autowala-test.firebaseio.com
FIREBASE_WEB_API_KEY=test-api-key
FIREBASE_SERVER_KEY=test-server-key

# Google Maps (Test)
GOOGLE_MAPS_API_KEY=test-maps-api-key

# Twilio SMS (Test mode)
SMS_PROVIDER=log
TWILIO_ACCOUNT_SID=ACtest
TWILIO_AUTH_TOKEN=test_token
TWILIO_PHONE_NUMBER=+15005550006

# App-specific
CORS_ALLOWED_ORIGINS=*
BACKUP_ARCHIVE_PASSWORD=test-password
