APP_NAME=AutoWala
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=Asia/Kolkata

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database Configuration (PostgreSQL + PostGIS)
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=autowala
DB_USERNAME=autowala_user
DB_PASSWORD=autowala_secure_password

# Redis Configuration
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Cache & Session
CACHE_DRIVER=redis
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=redis
SESSION_LIFETIME=120

# Email Configuration
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@autowala.in"
MAIL_FROM_NAME="${APP_NAME}"

# AWS Configuration
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-south-1
AWS_BUCKET=autowala-prod-storage
AWS_USE_PATH_STYLE_ENDPOINT=false

# Firebase Configuration
FIREBASE_PROJECT_ID=autowala-ride-discovery
FIREBASE_DATABASE_URL=https://autowala-ride-discovery-default-rtdb.asia-southeast1.firebasedatabase.app/
FIREBASE_CREDENTIALS=storage/app/private/firebase-service-account.json

# Google Services
GOOGLE_MAPS_API_KEY=
GOOGLE_PLACES_API_KEY=

# SMS Service Configuration
SMS_PROVIDER=aws_sns
SMS_FROM=AutoWala
AWS_SNS_REGION=ap-south-1

# JWT Configuration
JWT_SECRET=
JWT_TTL=30
JWT_REFRESH_TTL=1440
JWT_ALGO=HS256

# Pusher Configuration (for Web Socket)
BROADCAST_DRIVER=pusher
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=ap2

# Location Service Configuration
NEARBY_RIDERS_RADIUS_KM=5
LOCATION_UPDATE_INTERVAL_SEC=5
MAX_LOCATION_CACHE_TTL_SEC=30

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100
LOCATION_UPDATE_RATE_LIMIT=12

# Business Configuration
DEFAULT_FARE_PER_PASSENGER=30
CURRENCY_CODE=INR
MAX_PASSENGERS_PER_AUTO=3

# File Upload Configuration
MAX_PROFILE_PHOTO_SIZE_MB=5
MAX_DOCUMENT_SIZE_MB=10
ALLOWED_IMAGE_TYPES="jpeg,jpg,png,webp"
ALLOWED_DOCUMENT_TYPES="pdf,jpeg,jpg,png"

# Admin Configuration
ADMIN_DEFAULT_EMAIL=admin@autowala.in
ADMIN_DEFAULT_PASSWORD=AutoWala@2026!

# Security Configuration
API_VERSION=v1
CORS_ALLOWED_ORIGINS="http://localhost:3000,https://admin.autowala.in"
CSRF_PROTECTION=true