APP_NAME=AutoWala
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-app.up.railway.app

LOG_CHANNEL=stack
LOG_LEVEL=info

# Database - Railway provides DATABASE_URL automatically when you link PostgreSQL
# Laravel parses DATABASE_URL in config/database.php
# You can also set individual vars in Railway Variables tab:
#   DB_HOST, DB_PORT, DB_DATABASE, DB_USERNAME, DB_PASSWORD
DB_CONNECTION=pgsql

# Redis - Railway provides REDIS_URL when you link Redis
# You can also set: REDIS_HOST, REDIS_PORT, REDIS_PASSWORD
CACHE_DRIVER=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis

# Firebase
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_DATABASE_URL=https://your-project.firebaseio.com
FIREBASE_WEB_API_KEY=your-firebase-web-api-key

# Google Maps
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
