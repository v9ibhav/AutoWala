APP_NAME=AutoWala
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://autowala-backend-production.up.railway.app

LOG_CHANNEL=stack
LOG_LEVEL=info

# Database (Railway auto-provides these via DATABASE_URL)
DB_CONNECTION=pgsql
DB_HOST=${PGHOST}
DB_PORT=${PGPORT}
DB_DATABASE=${PGDATABASE}
DB_USERNAME=${PGUSER}
DB_PASSWORD=${PGPASSWORD}

# Redis (Railway auto-provides these)
REDIS_HOST=${REDIS_HOST}
REDIS_PASSWORD=${REDIS_PASSWORD}
REDIS_PORT=${REDIS_PORT}

CACHE_DRIVER=redis
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

# JWT Configuration
JWT_SECRET=base64:YourJWTSecretKeyHere1234567890abcdefghijklmnopqrstuvwxyz
JWT_TTL=60
JWT_REFRESH_TTL=20160
JWT_ALGO=HS256

# Firebase Configuration
FIREBASE_PROJECT_ID=autowala-6610e
FIREBASE_DATABASE_URL=https://autowala-6610e-default-rtdb.firebaseio.com
FIREBASE_WEB_API_KEY=AIzaSyB-_DaahfBLeej5zmD7Xouz8If5zJBf2JI
FIREBASE_SERVER_KEY=placeholder-fcm-server-key

# Google Maps
GOOGLE_MAPS_API_KEY=AIzaSyBdVl-cGnaq2rt_HEHhoqa_SkGBMiMeBiE

# Twilio SMS (Placeholder - Update with real credentials later)
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=AC1234567890abcdef1234567890abcdef
TWILIO_AUTH_TOKEN=your_auth_token_placeholder_12345678
TWILIO_PHONE_NUMBER=+1234567890

# App-specific
CORS_ALLOWED_ORIGINS=*
BACKUP_ARCHIVE_PASSWORD=your-backup-password